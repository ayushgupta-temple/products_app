  "item": [
    {
      "name": "Get All Products",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var jsonData = pm.response.json();\r",
              "\r",
              "pm.test(\"response to be 200 OK\", () => {\r",
              "    pm.response.to.have.status(200);\r",
              "})\r",
              "\r",
              "pm.test(\"value of [0].Id to be 1\", () => {\r",
              "    pm.expect(jsonData[0].id).to.eql(1);\r",
              "})\r",
              "\r",
              "pm.test(\"value of [0].name to be Tomato Soup\", () => {\r",
              "    pm.expect(jsonData[0].name).to.eql(\"Tomato Soup\");\r",
              "})\r",
              "\r",
              "pm.test(\"value of [0].category to be Groceries\", () => {\r",
              "    pm.expect(jsonData[0].category).to.eql(\"Groceries\");\r",
              "})\r",
              "\r",
              "pm.test(\"value of [0].price to be 1\", () => {\r",
              "    pm.expect(jsonData[0].price).to.eql(1);\r",
              "})"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:5243/api/products",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "5243",
          "path": [
            "api",
            "products"
          ]
        }
      },
      "response": []
